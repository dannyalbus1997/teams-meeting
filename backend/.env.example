# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/teams-meeting-summarizer

# Microsoft Azure AD / Graph API
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=http://localhost:3001/auth/callback

# AI Provider: "openai" | "anthropic" | "mock"
AI_PROVIDER=mock

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# Anthropic (if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Storage Provider: "local" | "s3" | "azure-blob"
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# AWS S3 (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=teams-meeting-recordings

# Azure Blob (if STORAGE_PROVIDER=azure-blob)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER=recordings

# Speech-to-Text Provider: "whisper-api" | "whisper-local" | "mock"
SPEECH_PROVIDER=mock
WHISPER_API_URL=http://localhost:9000/asr

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# ── Bot Configuration (for joining meetings as a bot) ──
# The bot uses Application permissions (not Delegated) via client credentials flow.
# It can be the same Azure App Registration or a separate one.
# Required Application permissions: Calls.JoinGroupCall.All, Calls.AccessMedia.All

# Bot App ID (can be same as AZURE_CLIENT_ID or a separate bot registration)
BOT_APP_ID=your-bot-app-id
BOT_APP_SECRET=your-bot-app-secret
BOT_TENANT_ID=your-tenant-id

# Public callback URL for Graph API call notifications (use ngrok for local dev)
# Run: ngrok http 3001
# Then set this to: https://your-id.ngrok-free.app/api
BOT_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/api