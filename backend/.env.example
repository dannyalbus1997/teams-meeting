# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/teams-meeting-summarizer

# Microsoft Azure AD / Graph API (App-Level Permissions)
# Uses client credentials flow — no user login required.
# Ensure you grant APPLICATION permissions (not Delegated) in Azure AD
# and that an admin has granted consent.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# The Azure AD Object ID (GUID) or UPN (user@domain.com) of the user
# whose calendar and meetings you want to sync.
AZURE_TARGET_USER_ID=user@yourdomain.com

# Required Azure AD Application Permissions (grant admin consent for these):
# - Calendars.Read                      (read user calendars)
# - OnlineMeetings.Read.All             (read online meeting details)
# - OnlineMeetingTranscript.Read.All    (read meeting transcripts)
# - OnlineMeetingRecording.Read.All     (read meeting recordings)
# - CallRecords.Read.All                (read call records — optional)
# - User.Read.All                       (read user profiles — optional)

# AI Provider: "openai" | "anthropic" | "mock"
AI_PROVIDER=mock

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# Anthropic (if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Storage Provider: "local" | "s3" | "azure-blob"
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# AWS S3 (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=teams-meeting-recordings

# Azure Blob (if STORAGE_PROVIDER=azure-blob)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER=recordings

# Speech-to-Text Provider: "whisper-api" | "whisper-local" | "mock"
SPEECH_PROVIDER=mock
WHISPER_API_URL=http://localhost:9000/asr

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
