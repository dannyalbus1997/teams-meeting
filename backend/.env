# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/teams-meeting-summarizer

# Microsoft Azure AD / Graph API
AZURE_TENANT_ID=f1f40c10-1148-405d-9f5c-118870603afa
AZURE_CLIENT_ID=0e7aeec1-d9ee-477f-adab-ddcf327d6e12
AZURE_CLIENT_SECRET=KHr8Q~3k~lVbR6-NyztQndOD3V8wCe8gtszNtbW4
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# AI Provider: "openai" | "anthropic" | "mock"
AI_PROVIDER=mock

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# Anthropic (if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Storage Provider: "local" | "s3" | "azure-blob"
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# AWS S3 (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=teams-meeting-recordings

# Azure Blob (if STORAGE_PROVIDER=azure-blob)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER=recordings

# Speech-to-Text Provider: "whisper-api" | "whisper-local" | "mock"
SPEECH_PROVIDER=mock
WHISPER_API_URL=http://localhost:9000/asr

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
